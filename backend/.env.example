APP_NAME=Veldooc Backend
ENV=development
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://patientagent.vercel.app

EPIC_CLIENT_ID=ffbfa6c6-03a5-488a-9d01-e1b066e3030c
EPIC_REDIRECT_URI=https://patientagent.vercel.app/callback.html
EPIC_AUTHORIZE_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize
EPIC_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token
EPIC_AUD=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_SCOPE=openid fhirUser launch/patient patient/*.read

OAUTH_STATE_TTL_SEC=600
WORKFLOW_CACHE_TTL_SEC=300
WORKFLOW_CACHE_KEY_PREFIX=ctx
WORKFLOW_CACHE_ENCRYPT=true
CONTEXT_ENCRYPTION_KEY=CHANGE_THIS_TO_A_LONG_SECRET
REDIS_URL=redis://localhost:6379/0
REDIS_REQUIRED=true

HL7_MLLP_ENABLED=false
HL7_MLLP_HOST=0.0.0.0
HL7_MLLP_PORT=2575
HL7_MLLP_SOURCE_ID=hl7-mllp

CONSENT_REQUIRED=true
CONSENT_SESSION_TTL_SEC=3600
PREFLIGHT_PAIN_THRESHOLD=7

ASR_BASE_URL=http://172.18.0.1:9001
ASR_TRANSCRIBE_PATH=/v1/audio/transcriptions
ASR_DEFAULT_LANGUAGE=en-US
ASR_TIMEOUT_SEC=60
ASR_AUTH_HEADER=Authorization
ASR_AUTH_TOKEN=
ASR_VERIFY_TLS=true
