APP_NAME=Veldooc Backend
ENV=development
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://patient-agent-interface.vercel.app

EPIC_CLIENT_ID=ffbfa6c6-03a5-488a-9d01-e1b066e3030c
EPIC_REDIRECT_URI=https://patient-agent-interface.vercel.app/callback.html
EPIC_AUTHORIZE_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize
EPIC_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token
EPIC_AUD=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_SCOPE=openid fhirUser launch/patient patient/*.read

OAUTH_STATE_TTL_SEC=600
STATE_SIGNING_KEY=CHANGE_THIS_TO_A_LONG_SIGNING_SECRET
WORKFLOW_CACHE_TTL_SEC=300
WORKFLOW_CACHE_KEY_PREFIX=ctx
WORKFLOW_CACHE_ENCRYPT=true
CONTEXT_ENCRYPTION_KEY=CHANGE_THIS_TO_A_LONG_SECRET
CTX_CACHE_TTL_SEC=300
TOKEN_CACHE_TTL_SEC=900
PROMPT_CACHE_TTL_SEC=300
REDIS_URL=redis://localhost:6379/0
REDIS_REQUIRED=true

HL7_MLLP_ENABLED=false
HL7_MLLP_HOST=0.0.0.0
HL7_MLLP_PORT=2575
HL7_MLLP_SOURCE_ID=hl7-mllp
CONNECTORS_FILE=docs/connectors.json
INTERNAL_API_KEY=dev-internal-key

CONSENT_REQUIRED=true
CONSENT_SESSION_TTL_SEC=3600
PREFLIGHT_PAIN_THRESHOLD=7

ASR_BASE_URL=http://172.18.0.1:9001
ASR_HEALTH_PATH=/v1/health/ready
ASR_TRANSCRIBE_PATH=/v1/audio/transcriptions
ASR_DEFAULT_LANGUAGE=en-US
ASR_TIMEOUT_SEC=60
ASR_AUTH_HEADER=Authorization
ASR_AUTH_TOKEN=
ASR_VERIFY_TLS=true

VOICE_ASR_MODE=http_chunk
RIVA_ASR_HTTP_URL=http://127.0.0.1:9001/v1/asr
RIVA_GRPC_TARGET=127.0.0.1:50052
RIVA_USE_SSL=false
RIVA_SAMPLE_RATE_HZ=16000
RIVA_LANGUAGE_CODE=en-US

NEMOGUARD_CONTENT_SAFETY_URL=http://127.0.0.1:8002/v1/guardrail
NEMOGUARD_TOPIC_CONTROL_URL=http://127.0.0.1:8003/v1/guardrail
NEMOGUARD_TOPIC_DIR=config/topics
NEMOGUARD_ENABLED=true
NEMOGUARD_CONTENT_ENABLED=true
NEMOGUARD_TOPIC_ENABLED=true
NEMOGUARD_FAIL_OPEN=false
NEMOGUARD_STRICT_ORDER=true
NEMOGUARD_CONTENT_MODEL=llama-nemotron-safety-guard-v2
NEMOGUARD_TOPIC_MODEL=llama-nemotron-topic-guard-v1

MEDGEMMA_BASE_URL=http://127.0.0.1:8080/v1
MEDGEMMA_API_KEY=not-used
MEDGEMMA_MODE=mvp
MEDGEMMA_MVP_MODEL=med-4b
MEDGEMMA_SPRINT3_MODEL=google/medgemma-27b-it
MEDGEMMA_MAX_TOKENS=1024
MEDGEMMA_MAX_MODEL_LEN=4096
MEDGEMMA_GPU_MEMORY_UTILIZATION=0.45
MEDGEMMA_MAX_NUM_SEQS=8
MEDGEMMA_MAX_NUM_BATCHED_TOKENS=2048
MEDGEMMA_DTYPE=bfloat16
MEDGEMMA_ENABLE_CHUNKED_PREFILL=true
MEDGEMMA_GPU_DEVICE=0

ASR_GPU_DEVICE=0
ASR_SHM_SIZE=8GB

NEMOGUARD_CS_GPU_DEVICE=0
NEMOGUARD_CS_SHM_SIZE=16GB
NEMOGUARD_TC_GPU_DEVICE=0
NEMOGUARD_TC_SHM_SIZE=16GB

TTS_NIM_URL=http://127.0.0.1:8000/v1/tts
